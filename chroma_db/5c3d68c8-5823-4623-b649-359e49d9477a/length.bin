, {"id": "667eb6a2f4d23a87c3ea2103", "text": "\"\ud83d\ude04 Sa\u00e9 %greeting, %name! Naon anu bisa kuring pigaw\u00e9 pikeun anjeun?\""}, {"id": "667eb6a2f4d23a87c3ea2164", "text": "\ud83d\ude04 Hello! Dupi anjeun gaduh patarosan pikeun kuring?"}, {"id": "667eb6a2f4d23a87c3ea21c5", "text": "\ud83d\ude4f Namaste! Naon brings anjeun dina dinten?"}]}, "sw": {"sw": [{"id": "667eb6a1f4d23a87c3ea1ebe